/* app.wxss — 全局样式变量与基础重置 */

page {
  --color-primary: #FF9F43;
  --color-primary-light: #FFF5E6;
  --color-bg: #FFF9F0;
  --color-white: #ffffff;
  --color-text: #333333;
  --color-gray: #999999;
  --color-border: #eeeeee;
  --color-green: #26DE81;

  background-color: var(--color-bg);
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", sans-serif;
  font-size: 28rpx;
  color: var(--color-text);
  box-sizing: border-box;
}

/* 通用导航栏 */
.nav-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 88rpx;
  padding: 0 32rpx;
  border-bottom: 1rpx solid var(--color-border);
  background: var(--color-bg);
}

.nav-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-primary);
}

.nav-title-sm {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
}

.nav-back {
  font-size: 30rpx;
  color: var(--color-primary);
  padding: 10rpx 0;
}

.nav-icon {
  font-size: 44rpx;
}

/* 通用按钮 */
.btn-primary {
  background: var(--color-primary);
  color: #fff;
  border-radius: 48rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
}

.btn-secondary {
  background: var(--color-white);
  color: var(--color-primary);
  border-radius: 48rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 500;
  border: 2rpx solid var(--color-primary);
}

/* 通用卡片 */
.card {
  background: var(--color-white);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

/* section 标签 */
.section-label {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-gray);
  margin-bottom: 20rpx;
  display: block;
}
