<!-- pages/health/index.wxml -->
<view class="page">
  <!-- 状态栏占位 -->
  <view style="height: {{statusBarHeight}}px;"></view>

  <!-- 导航栏 -->
  <view class="nav-bar" style="height: {{navBarHeight}}px;">
    <navigator open-type="navigateBack" class="nav-back">← 返回</navigator>
    <text class="nav-title-sm">💊 宠物健康</text>
    <view style="width:80rpx;"></view>
  </view>

  <!-- AI 问诊入口横幅 -->
  <view class="ask-banner" bindtap="goAskVet">
    <view class="ask-banner-left">
      <text class="ask-banner-icon">🩺</text>
      <view>
        <text class="ask-banner-title">AI 宠物问诊</text>
        <text class="ask-banner-sub">描述症状，秒获专业建议</text>
      </view>
    </view>
    <text class="ask-banner-arrow">→</text>
  </view>

  <!-- 分类 Tab -->
  <view class="tab-row">
    <view
      wx:for="{{tabs}}" wx:key="*this"
      class="tab-btn {{activeTab === item ? 'tab-active' : ''}}"
      bindtap="switchTab"
      data-tab="{{item}}"
    >{{item}}</view>
  </view>

  <!-- 健康知识卡片列表 -->
  <scroll-view scroll-y class="knowledge-list">
    <view
      wx:for="{{filteredList}}" wx:key="_id"
      class="knowledge-card"
      bindtap="openDetail"
      data-id="{{item._id}}"
    >
      <view class="kc-header">
        <view class="kc-tag" style="background:{{item.tagColor}}20; color:{{item.tagColor}}">
          {{item.tag}}
        </view>
        <text class="kc-pet">{{item.petLabel}}</text>
      </view>
      <text class="kc-title">{{item.title}}</text>
      <text class="kc-desc">{{item.summary}}</text>
      <view class="kc-footer">
        <text class="kc-read">阅读全文 →</text>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-wrap" wx:if="{{filteredList.length === 0}}">
      <text class="empty-icon">🔍</text>
      <text class="empty-text">暂无相关内容</text>
    </view>
  </scroll-view>

  <!-- 知识详情弹层 -->
  <view class="detail-mask" wx:if="{{showDetail}}" bindtap="closeDetail">
    <view class="detail-sheet" catchtap="noop">
      <view class="detail-header">
        <text class="detail-title">{{currentItem.title}}</text>
        <view class="detail-close" bindtap="closeDetail">✕</view>
      </view>
      <scroll-view scroll-y class="detail-body">
        <view class="detail-tag-row">
          <view class="kc-tag" style="background:{{currentItem.tagColor}}20; color:{{currentItem.tagColor}}">
            {{currentItem.tag}}
          </view>
          <text class="detail-pet">{{currentItem.petLabel}}</text>
        </view>
        <text class="detail-content">{{currentItem.content}}</text>

        <!-- 相关症状提示 -->
        <view class="detail-symptoms" wx:if="{{currentItem.symptoms && currentItem.symptoms.length > 0}}">
          <text class="detail-symptoms-title">⚠️ 需要就医的信号</text>
          <view wx:for="{{currentItem.symptoms}}" wx:key="*this" wx:for-item="s" class="symptom-item">
            <text class="symptom-dot">•</text>
            <text class="symptom-text">{{s}}</text>
          </view>
        </view>

        <!-- 底部问诊引导 -->
        <view class="detail-ask-btn" bindtap="goAskVetWithTopic">
          <text>🩺 有疑问？问问 AI 宠物医生</text>
        </view>
      </scroll-view>
    </view>
  </view>
</view>
