/* pages/health/index.wxss */

.page {
  background: var(--color-bg);
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* ---- 导航栏 ---- */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 28rpx;
  background: var(--color-bg);
  border-bottom: 1rpx solid var(--color-border);
  flex-shrink: 0;
}

.nav-back {
  font-size: 28rpx;
  color: var(--color-primary);
  padding: 10rpx 0;
  min-width: 100rpx;
  font-weight: 500;
}

.nav-title-sm {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text);
  text-align: center;
  flex: 1;
}

/* ---- AI 问诊横幅 ---- */
.ask-banner {
  margin: 20rpx 28rpx 0;
  background: linear-gradient(135deg, #FF9F43, #FF7043);
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 6rpx 24rpx rgba(255, 159, 67, 0.30);
  flex-shrink: 0;
}

.ask-banner-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.ask-banner-icon {
  font-size: 48rpx;
  line-height: 1;
}

.ask-banner-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 6rpx;
}

.ask-banner-sub {
  display: block;
  font-size: 22rpx;
  color: rgba(255,255,255,0.85);
}

.ask-banner-arrow {
  font-size: 32rpx;
  color: rgba(255,255,255,0.90);
  font-weight: 600;
}

/* ---- 分类 Tab（与百科一致）---- */
.tab-row {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  padding: 20rpx 28rpx 16rpx;
  flex-shrink: 0;
}

.tab-btn {
  padding: 12rpx 36rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: var(--color-gray);
  background: var(--color-white);
  border: 2rpx solid var(--color-border);
  font-weight: 500;
}

.tab-active {
  background: var(--color-primary);
  color: #fff;
  border-color: var(--color-primary);
  font-weight: 600;
}

/* ---- 知识列表 ---- */
.knowledge-list {
  flex: 1;
  height: 0;
}

.knowledge-card {
  background: var(--color-white);
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  margin: 0 28rpx 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
}

.knowledge-card:active {
  opacity: 0.85;
}

.kc-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.kc-tag {
  font-size: 22rpx;
  font-weight: 600;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
}

.kc-pet {
  font-size: 22rpx;
  color: var(--color-gray);
}

.kc-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 12rpx;
  line-height: 1.4;
}

.kc-desc {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.75;
  margin-bottom: 18rpx;
}

.kc-footer {
  display: flex;
  justify-content: flex-end;
}

.kc-read {
  font-size: 24rpx;
  color: var(--color-primary);
  font-weight: 500;
}

/* ---- 空状态 ---- */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 72rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--color-gray);
}

/* ---- 列表底部留白 ---- */
.list-bottom {
  height: 40rpx;
}

/* ---- 详情弹层 ---- */
.detail-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.50);
  z-index: 9999;
  display: flex;
  align-items: flex-end;
}

.detail-sheet {
  background: var(--color-bg);
  border-radius: 32rpx 32rpx 0 0;
  width: 100%;
  max-height: 88vh;
  display: flex;
  flex-direction: column;
  box-shadow: 0 -4rpx 32rpx rgba(0, 0, 0, 0.12);
}

/* ---- 弹层顶部拖动条 ---- */
.detail-drag-bar {
  display: flex;
  justify-content: center;
  padding: 16rpx 0 4rpx;
  flex-shrink: 0;
}

.detail-drag-bar-inner {
  width: 64rpx;
  height: 6rpx;
  background: rgba(0, 0, 0, 0.10);
  border-radius: 6rpx;
}

/* ---- 弹层标题区 ---- */
.detail-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 20rpx 32rpx 24rpx;
  flex-shrink: 0;
}

.detail-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text);
  flex: 1;
  line-height: 1.45;
  padding-right: 20rpx;
}

.detail-close-btn {
  width: 56rpx;
  height: 56rpx;
  background: var(--color-border);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.detail-close-icon {
  font-size: 28rpx;
  color: var(--color-gray);
  line-height: 1;
  font-weight: 600;
}

/* ---- 弹层标签行 ---- */
.detail-meta-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 0 32rpx 24rpx;
  flex-shrink: 0;
  border-bottom: 1rpx solid var(--color-border);
}

.detail-pet {
  font-size: 24rpx;
  color: var(--color-gray);
}

/* ---- 弹层内容区 ---- */
.detail-body {
  flex: 1;
  height: 0;          /* 配合 flex:1 让 scroll-view 能正确计算高度 */
  background: var(--color-bg);
}

.detail-body-inner {
  padding: 24rpx 28rpx 48rpx;
}

.detail-content-card {
  background: var(--color-white);
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.detail-content {
  display: block;
  font-size: 28rpx;
  color: var(--color-text);
  line-height: 1.90;
  white-space: pre-wrap;
}

/* 需要就医的信号 */
.detail-symptoms {
  background: #FFFBEB;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 28rpx;
  border: 2rpx solid rgba(255, 193, 7, 0.40);
}

.detail-symptoms-title {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #92640C;
  margin-bottom: 18rpx;
}

.symptom-item {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  margin-bottom: 14rpx;
}

.symptom-dot {
  color: #D97706;
  font-size: 22rpx;
  margin-top: 4rpx;
  flex-shrink: 0;
}

.symptom-text {
  font-size: 26rpx;
  color: #92640C;
  flex: 1;
  line-height: 1.6;
}


