/* pages/health/index.wxss */

.page {
  background: var(--color-bg);
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* ---- AI 问诊横幅 ---- */
.ask-banner {
  margin: 20rpx 32rpx 24rpx;
  background: linear-gradient(135deg, #FF9F43, #FF7043);
  border-radius: 24rpx;
  padding: 32rpx 36rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 8rpx 32rpx rgba(255, 159, 67, 0.35);
}

.ask-banner-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.ask-banner-icon {
  font-size: 56rpx;
  line-height: 1;
}

.ask-banner-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 6rpx;
}

.ask-banner-sub {
  display: block;
  font-size: 22rpx;
  color: rgba(255,255,255,0.85);
}

.ask-banner-arrow {
  font-size: 36rpx;
  color: #fff;
  font-weight: 700;
}

/* ---- 分类 Tab ---- */
.tab-row {
  display: flex;
  gap: 16rpx;
  padding: 0 32rpx 24rpx;
}

.tab-btn {
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: var(--color-gray);
  background: var(--color-white);
  border: 2rpx solid var(--color-border);
  transition: all 0.15s;
}

.tab-active {
  color: var(--color-primary);
  background: var(--color-primary-light);
  border-color: var(--color-primary);
  font-weight: 600;
}

/* ---- 知识列表 ---- */
.knowledge-list {
  flex: 1;
  padding: 0 32rpx 40rpx;
  height: calc(100vh - 480rpx);  /* 留出导航栏+横幅+tab 高度 */
}

.knowledge-card {
  background: var(--color-white);
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
}

.kc-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.kc-tag {
  font-size: 22rpx;
  font-weight: 600;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
}

.kc-pet {
  font-size: 22rpx;
  color: var(--color-gray);
}

.kc-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 12rpx;
  line-height: 1.4;
}

.kc-desc {
  display: block;
  font-size: 26rpx;
  color: var(--color-gray);
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.kc-footer {
  display: flex;
  justify-content: flex-end;
}

.kc-read {
  font-size: 24rpx;
  color: var(--color-primary);
  font-weight: 500;
}

/* ---- 空状态 ---- */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--color-gray);
}

/* ---- 详情弹层 ---- */
.detail-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}

.detail-sheet {
  background: var(--color-white);
  border-radius: 32rpx 32rpx 0 0;
  width: 100%;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
}

.detail-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 36rpx 36rpx 24rpx;
  border-bottom: 1rpx solid var(--color-border);
  flex-shrink: 0;
}

.detail-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
  flex: 1;
  line-height: 1.4;
  padding-right: 24rpx;
}

.detail-close {
  font-size: 36rpx;
  color: var(--color-gray);
  padding: 0 8rpx;
  flex-shrink: 0;
}

.detail-body {
  flex: 1;
  padding: 28rpx 36rpx 40rpx;
}

.detail-tag-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.detail-pet {
  font-size: 24rpx;
  color: var(--color-gray);
}

.detail-content {
  display: block;
  font-size: 28rpx;
  color: var(--color-text);
  line-height: 1.8;
  white-space: pre-wrap;
  margin-bottom: 32rpx;
}

/* 需要就医的信号 */
.detail-symptoms {
  background: #FFF8E1;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 32rpx;
  border-left: 6rpx solid #FFC107;
}

.detail-symptoms-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #856404;
  margin-bottom: 16rpx;
}

.symptom-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 10rpx;
}

.symptom-dot {
  color: #856404;
  margin-right: 10rpx;
  font-size: 28rpx;
}

.symptom-text {
  font-size: 26rpx;
  color: #856404;
  flex: 1;
  line-height: 1.5;
}

/* 底部问诊按钮 */
.detail-ask-btn {
  background: linear-gradient(135deg, #FF9F43, #FF7043);
  border-radius: 48rpx;
  padding: 28rpx;
  text-align: center;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}
