/* pages/checkin/index.wxss */

.page {
  background: var(--color-bg);
  min-height: 100vh;
}

.content {
  padding: 32rpx;
}

/* 宠物行 */
.pet-row {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.pet-ava {
  width: 80rpx;
  height: 80rpx;
  background: #FFE4C4;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-right: 20rpx;
}

.pet-nm {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-text);
}

/* 今日已打卡 */
.checked-tip {
  background: #F0FFF4;
  border-radius: 20rpx;
  padding: 40rpx;
  text-align: center;
  font-size: 32rpx;
  color: var(--color-green);
  margin-bottom: 32rpx;
}

/* 心情宫格 */
.mood-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.mood-item {
  background: var(--color-white);
  border-radius: 20rpx;
  padding: 28rpx 12rpx;
  text-align: center;
  border: 2rpx solid transparent;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: all 0.2s;
}

.mood-item.selected {
  border-color: var(--color-primary);
  background: var(--color-primary-light);
}

.mood-emoji {
  font-size: 52rpx;
  display: block;
  margin-bottom: 10rpx;
}

.mood-label {
  font-size: 24rpx;
  color: #666;
}

/* 备注 */
.note-wrap {
  margin-bottom: 40rpx;
  padding: 24rpx;
}

.note-input {
  width: 100%;
  font-size: 28rpx;
  color: var(--color-text);
  min-height: 100rpx;
  line-height: 1.6;
}

/* 打卡按钮 */
.checkin-btn {
  width: 100%;
  height: 96rpx;
  background: var(--color-primary);
  border-radius: 48rpx;
  color: white;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  line-height: 96rpx;
}

/* 连续打卡 */
.streak-text {
  display: block;
  text-align: center;
  color: var(--color-green);
  font-size: 28rpx;
  margin-top: 28rpx;
}
