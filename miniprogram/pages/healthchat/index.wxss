/* pages/health-chat/index.wxss */

.page {
  background: linear-gradient(180deg, #FFF9F0 0%, #FFF5E6 100%);
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* ---- 顶部固定区域 ---- */
.top-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: linear-gradient(180deg, rgba(255, 249, 240, 0.98) 0%, rgba(255, 245, 230, 0.95) 100%);
  backdrop-filter: blur(10rpx);
  border-bottom: 1rpx solid rgba(255, 159, 67, 0.1);
  z-index: 100;
}

.nav-content {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100%;
  position: relative;
  box-sizing: border-box;
}

.nav-back {
  position: absolute;
  left: 32rpx;
  font-size: 30rpx;
  color: var(--color-primary);
  padding: 10rpx 0;
  font-weight: 500;
}

.nav-title-sm {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
}

.nav-clear {
  font-size: 26rpx;
  color: var(--color-primary);
  padding: 10rpx 16rpx;
  background: rgba(255, 159, 67, 0.1);
  border-radius: 20rpx;
  font-weight: 500;
}

/* ---- 聊天列表 ---- */
.chat-list {
  flex: 1;
  padding: 24rpx 28rpx 0;
  box-sizing: border-box;
}

/* ---- 欢迎区域 ---- */
.chat-welcome {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx 40rpx;
  position: relative;
}

.chat-welcome::before {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(255, 159, 67, 0.15) 0%, transparent 70%);
  border-radius: 50%;
}

.chat-welcome-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  animation: float 3s ease-in-out infinite;
  position: relative;
  z-index: 1;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

.chat-welcome-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 16rpx;
  position: relative;
  z-index: 1;
}

.chat-welcome-sub {
  font-size: 26rpx;
  color: var(--color-gray);
  text-align: center;
  line-height: 1.8;
  margin-bottom: 48rpx;
  max-width: 500rpx;
  position: relative;
  z-index: 1;
}

/* 快捷问题 */
.quick-questions {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  justify-content: center;
  width: 100%;
  position: relative;
  z-index: 1;
}

.quick-btn {
  background: linear-gradient(135deg, #FFFFFF 0%, #FFF9F0 100%);
  border: 2rpx solid rgba(255, 159, 67, 0.2);
  border-radius: 40rpx;
  padding: 18rpx 32rpx;
  font-size: 26rpx;
  color: var(--color-text);
  box-shadow: 0 4rpx 16rpx rgba(255, 159, 67, 0.08);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.quick-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 159, 67, 0.1), transparent);
  transition: left 0.5s ease;
}

.quick-btn:active::before {
  left: 100%;
}

/* ---- 消息行 ---- */
.msg-row {
  display: flex;
  align-items: flex-end;
  margin-bottom: 32rpx;
  gap: 16rpx;
  animation: fadeInUp 0.4s ease;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.msg-left {
  flex-direction: row;
}

.msg-right {
  flex-direction: row-reverse;
}

/* 头像 */
.msg-avatar {
  font-size: 40rpx;
  width: 68rpx;
  height: 68rpx;
  background: linear-gradient(135deg, #FFFFFF 0%, #FFF9F0 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(255, 159, 67, 0.15);
  border: 2rpx solid rgba(255, 159, 67, 0.2);
}

.user-avatar {
  background: linear-gradient(135deg, #FF9F43 0%, #FF7F30 100%);
  border: none;
}

/* 气泡 */
.msg-bubble {
  max-width: 70%;
  padding: 24rpx 28rpx;
  border-radius: 28rpx;
  line-height: 1.8;
  position: relative;
}

.bubble-user {
  background: linear-gradient(135deg, #FF9F43 0%, #FF7F30 100%);
  border-bottom-right-radius: 10rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 159, 67, 0.3);
}

.bubble-ai {
  background: linear-gradient(135deg, #FFFFFF 0%, #FFF9F0 100%);
  border-bottom-left-radius: 10rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(255, 159, 67, 0.15);
}

.msg-text {
  font-size: 28rpx;
  white-space: pre-wrap;
  word-break: break-all;
}

.bubble-user .msg-text {
  color: #fff;
  font-weight: 500;
}

.bubble-ai .msg-text {
  color: var(--color-text);
}

/* loading 气泡 */
.bubble-loading {
  min-width: 100rpx;
  min-height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-dots {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF9F43 0%, #FF7F30 100%);
  animation: dotBounce 1.4s infinite ease-in-out;
}

.dot2 { animation-delay: 0.2s; }
.dot3 { animation-delay: 0.4s; }

@keyframes dotBounce {
  0%, 80%, 100% { transform: scale(0.5); opacity: 0.3; }
  40%           { transform: scale(1);   opacity: 1; }
}

/* ---- 输入栏 ---- */
.input-bar {
  display: flex;
  align-items: flex-end;
  gap: 20rpx;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(255, 249, 240, 0.98) 100%);
  border-top: 1rpx solid rgba(255, 159, 67, 0.15);
  box-sizing: border-box;
  flex-shrink: 0;
  backdrop-filter: blur(10rpx);
}

.input-box {
  flex: 1;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 22rpx 28rpx;
  font-size: 28rpx;
  color: var(--color-text);
  min-height: 80rpx;
  max-height: 220rpx;
  line-height: 1.6;
  border: 2rpx solid #E8E8E8;
  transition: all 0.3s ease;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.input-box:focus {
  border-color: var(--color-primary);
  box-shadow: 0 0 0 4rpx rgba(255, 159, 67, 0.12), 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.input-placeholder {
  color: #C8C8C8;
}

.send-btn {
  width: 84rpx;
  height: 84rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFB366 0%, #FF9F43 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.3s ease;
  box-shadow: 0 6rpx 20rpx rgba(255, 159, 67, 0.35);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.send-btn:active {
  transform: scale(0.92);
}

.send-active {
  background: linear-gradient(135deg, #FF9F43 0%, #FF7F30 100%);
  box-shadow: 0 8rpx 28rpx rgba(255, 159, 67, 0.5);
  transform: scale(1.08);
}

.send-active:active {
  transform: scale(0.95);
}

.send-icon {
  font-size: 38rpx;
  color: #fff;
  font-weight: 700;
  line-height: 1;
}
