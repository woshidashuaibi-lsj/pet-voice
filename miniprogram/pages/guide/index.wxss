/* pages/guide/index.wxss */

.page {
  background: var(--color-bg);
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* ---- 导航栏（与百科一致的暖色风格）---- */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 28rpx;
  background: var(--color-bg);
  border-bottom: 1rpx solid var(--color-border);
  flex-shrink: 0;
}

.nav-back {
  font-size: 28rpx;
  color: var(--color-primary);
  padding: 10rpx 0;
  min-width: 100rpx;
  font-weight: 500;
}

.nav-title-sm {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text);
  text-align: center;
  flex: 1;
}

/* ---- 猫狗切换 Tab（与百科 Tab 保持一致）---- */
.tab-row {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  padding: 20rpx 28rpx 16rpx;
  flex-shrink: 0;
}

.tab-btn {
  padding: 12rpx 48rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: var(--color-gray);
  background: var(--color-white);
  border: 2rpx solid var(--color-border);
  font-weight: 500;
}

.tab-active {
  background: var(--color-primary);
  color: #fff;
  border-color: var(--color-primary);
  font-weight: 600;
}

/* ---- 阶段滚动区 ---- */
.stage-scroll {
  flex: 1;
  height: 0;
}

/* ---- 阶段 section ---- */
.stage-section {
  margin-bottom: 8rpx;
}

.stage-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 28rpx 12rpx;
}

.stage-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.stage-title {
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  text-transform: uppercase;
}

/* ---- 指南卡片（与百科卡片风格一致）---- */
.guide-card {
  background: var(--color-white);
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  margin: 0 28rpx 16rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
}

.guide-card:active {
  opacity: 0.85;
}

.gc-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  background: var(--color-primary-light);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.gc-icon {
  font-size: 42rpx;
}

.gc-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  min-width: 0;
}

.gc-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text);
  line-height: 1.4;
}

.gc-footer {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.gc-arrow {
  font-size: 24rpx;
  color: var(--color-primary);
  font-weight: 500;
}

.gc-chevron {
  font-size: 28rpx;
  color: var(--color-primary);
  font-weight: 400;
  line-height: 1;
}

/* ---- 底部底部留白 ---- */
.list-bottom {
  height: 40rpx;
}

/* ========== 详情弹层 ========== */
.detail-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.50);
  z-index: 9999;
  display: flex;
  align-items: flex-end;
}

.detail-sheet {
  background: var(--color-white);
  border-radius: 32rpx 32rpx 0 0;
  width: 100%;
  max-height: 88vh;
  display: flex;
  flex-direction: column;
  box-shadow: 0 -4rpx 32rpx rgba(0, 0, 0, 0.12);
}

.detail-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 36rpx 32rpx 24rpx;
  border-bottom: 1rpx solid var(--color-border);
  flex-shrink: 0;
  position: relative;
}

/* 顶部拖动指示条 */
.detail-header::before {
  content: '';
  position: absolute;
  top: 16rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 64rpx;
  height: 6rpx;
  background: rgba(0, 0, 0, 0.08);
  border-radius: 6rpx;
}

.detail-title-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  padding-right: 20rpx;
}

.detail-icon {
  font-size: 40rpx;
  flex-shrink: 0;
}

.detail-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
  line-height: 1.4;
  flex: 1;
}

.detail-close {
  font-size: 36rpx;
  color: var(--color-gray);
  padding: 0 8rpx;
  flex-shrink: 0;
  line-height: 1;
}

.detail-body {
  flex: 1;
  height: 0;          /* 配合 flex:1 让 scroll-view 能正确计算高度 */
  padding: 28rpx 32rpx 48rpx;
}

.detail-content {
  display: block;
  font-size: 28rpx;
  color: var(--color-text);
  line-height: 1.85;
  white-space: pre-wrap;
}
