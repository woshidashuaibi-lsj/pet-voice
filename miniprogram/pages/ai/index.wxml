<!-- pages/ai/index.wxml -->
<view class="page">
  <view style="height: {{statusBarHeight}}px;"></view>

  <!-- 导航栏 -->
  <view class="nav-bar" style="height: {{navBarHeight}}px;">
    <view style="width:80rpx;"></view>
    <text class="nav-title">🤖 宠物助手</text>
    <view style="width:80rpx;"></view>
  </view>

  <!-- 主内容区 -->
  <scroll-view scroll-y class="content-scroll">
    <!-- 欢迎区域 -->
    <view class="welcome-section">
      <text class="welcome-icon">✨</text>
      <text class="welcome-title">宠物助手</text>
      <text class="welcome-sub">专业宠物知识，随时为您解答</text>
    </view>

    <!-- 专属服务卡片 -->
    <view class="services-section">
      <text class="section-title">📌 专属服务</text>

      <view wx:for="{{aiServices}}" wx:key="id" class="service-card" bindtap="goToService" data-path="{{item.path}}">
        <view class="service-icon" style="background: {{item.color}}20;">
          <text>{{item.icon}}</text>
        </view>
        <view class="service-info">
          <text class="service-title">{{item.title}}</text>
          <text class="service-desc">{{item.desc}}</text>
        </view>
        <text class="service-arrow">→</text>
      </view>
    </view>

    <!-- 健康问题 -->
    <view class="quick-section">
      <text class="section-title">🏥 健康咨询</text>

      <view class="quick-questions">
        <view wx:for="{{healthQuestions}}" wx:key="*this" class="quick-btn" bindtap="sendHealthQuestion" data-question="{{item}}">
          <text class="quick-icon">❓</text>
          <text class="quick-text">{{item}}</text>
        </view>
      </view>
    </view>

    <!-- 训练问题 -->
    <view class="quick-section">
      <text class="section-title">🎓 训练咨询</text>

      <view class="quick-questions">
        <view wx:for="{{trainingQuestions}}" wx:key="*this" class="quick-btn" bindtap="sendTrainingQuestion" data-question="{{item}}">
          <text class="quick-icon">❓</text>
          <text class="quick-text">{{item}}</text>
        </view>
      </view>
    </view>

    <!-- 提示信息 -->
    <view class="tip-section">
      <view class="tip-card">
        <text class="tip-icon">💡</text>
        <text class="tip-text">本服务基于专业宠物知识库，为您提供参考建议。如遇紧急情况，请及时就医。</text>
      </view>
    </view>

    <view style="height: 40rpx;"></view>
  </scroll-view>
</view>
