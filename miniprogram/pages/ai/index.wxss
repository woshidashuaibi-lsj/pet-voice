/* pages/ai/index.wxss */

.page {
  background: linear-gradient(180deg, #FFF9F0 0%, #FFF5E6 100%);
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* ---- 导航栏 ---- */
.nav-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 32rpx;
  background: linear-gradient(180deg, rgba(255, 249, 240, 0.98) 0%, rgba(255, 245, 230, 0.95) 100%);
  backdrop-filter: blur(10rpx);
  border-bottom: 1rpx solid rgba(255, 159, 67, 0.1);
}

.nav-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-primary);
}

/* ---- 主内容滚动区 ---- */
.content-scroll {
  flex: 1;
  padding: 0 32rpx 120rpx;
  box-sizing: border-box;
}

/* ---- 欢迎区域 ---- */
.welcome-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx 40rpx;
  position: relative;
}

.welcome-section::before {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 280rpx;
  height: 280rpx;
  background: radial-gradient(circle, rgba(255, 159, 67, 0.12) 0%, transparent 70%);
  border-radius: 50%;
}

.welcome-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  animation: float 3s ease-in-out infinite;
  position: relative;
  z-index: 1;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12rpx); }
}

.welcome-title {
  font-size: 42rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 12rpx;
  position: relative;
  z-index: 1;
}

.welcome-sub {
  font-size: 26rpx;
  color: var(--color-gray);
  text-align: center;
  line-height: 1.6;
  position: relative;
  z-index: 1;
}

/* ---- 区块标题 ---- */
.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 24rpx;
}

/* ---- AI 服务卡片 ---- */
.services-section {
  margin-bottom: 40rpx;
}

.service-card {
  background: linear-gradient(135deg, #FFFFFF 0%, #FFF9F0 100%);
  border-radius: 28rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  border: 2rpx solid rgba(255, 159, 67, 0.1);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.service-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, var(--color-primary) 0%, transparent 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.service-card:active {
  transform: translateY(-4rpx);
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.1);
}

.service-card:active::before {
  opacity: 1;
}

.service-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  flex-shrink: 0;
  position: relative;
  z-index: 1;
}

.service-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  position: relative;
  z-index: 1;
}

.service-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
}

.service-desc {
  font-size: 24rpx;
  color: var(--color-gray);
  line-height: 1.5;
}

.service-arrow {
  font-size: 36rpx;
  color: var(--color-gray);
  font-weight: 600;
  position: relative;
  z-index: 1;
}

/* ---- 快捷问题 ---- */
.quick-section {
  margin-bottom: 40rpx;
}

.quick-questions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.quick-btn {
  background: linear-gradient(135deg, #FFFFFF 0%, #FFF9F0 100%);
  border: 2rpx solid rgba(255, 159, 67, 0.15);
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 159, 67, 0.08);
  transition: all 0.3s ease;
}

.quick-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 159, 67, 0.08), transparent);
  transition: left 0.5s ease;
}

.quick-btn:active::before {
  left: 100%;
}

.quick-btn:active {
  transform: scale(0.98);
  border-color: var(--color-primary);
}

.quick-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

.quick-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text);
  line-height: 1.5;
}

/* ---- 提示信息 ---- */
.tip-section {
  margin-bottom: 40rpx;
}

.tip-card {
  background: linear-gradient(135deg, #FFF5E6 0%, #FFECD6 100%);
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  border: 2rpx solid rgba(255, 159, 67, 0.2);
}

.tip-icon {
  font-size: 32rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.tip-text {
  flex: 1;
  font-size: 24rpx;
  color: var(--color-text);
  line-height: 1.7;
}
