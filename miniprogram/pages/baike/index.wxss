/* pages/baike/index.wxss */

.page {
  background: var(--color-bg);
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* 搜索栏 */
.search-wrap {
  padding: 24rpx 32rpx;
}

.search-input {
  width: 100%;
  padding: 20rpx 28rpx;
  background: var(--color-white);
  border-radius: 48rpx;
  font-size: 28rpx;
  color: var(--color-text);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 分类 Tab */
.tab-row {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  padding: 0 32rpx 24rpx;
}

.tab-btn {
  padding: 14rpx 40rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  background: #f0f0f0;
  color: #666;
}

.tab-btn.active {
  background: var(--color-primary);
  color: white;
}

/* 列表 */
.baike-list {
  flex: 1;
  padding: 0 32rpx;
  height: 0;
  min-height: 400rpx;
}

.baike-card {
  margin-bottom: 20rpx;
}

.baike-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.baike-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
}

.baike-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.7;
  display: block;
  margin-bottom: 16rpx;
}

/* 标签 */
.tag-row {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.tag {
  background: #F0F0F0;
  color: #666;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

/* 空状态 */
.empty-wrap {
  padding: 120rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 28rpx;
  color: var(--color-gray);
}
