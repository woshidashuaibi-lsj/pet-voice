<!-- pages/baike/index.wxml -->
<view class="page">
  <!-- 状态栏占位 -->
  <view style="height: {{statusBarHeight}}px;"></view>

  <!-- 导航栏：返回 + 居中标题 -->
  <view class="nav-bar" style="height: {{navBarHeight}}px;">
    <navigator open-type="navigateBack" class="nav-back-btn">← 返回</navigator>
    <text class="nav-title-center">📖 宠物百科</text>
    <view style="width:100rpx;"></view>
  </view>

  <!-- 搜索栏 -->
  <view class="search-wrap">
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="搜索行为关键词..."
        placeholder-class="search-placeholder"
        bindinput="onSearch"
        confirm-type="search"
      />
    </view>
  </view>

  <!-- 分类 Tab -->
  <view class="tab-row">
    <view
      wx:for="{{tabs}}"
      wx:key="*this"
      class="tab-btn {{activeTab === item ? 'tab-active' : ''}}"
      bindtap="switchTab"
      data-tab="{{item}}"
    >{{item}}</view>
  </view>

  <!-- 百科列表 -->
  <scroll-view scroll-y class="baike-list">
    <view wx:if="{{filteredList.length === 0}}" class="empty-wrap">
      <text class="empty-icon">🔍</text>
      <text class="empty-text">没有找到相关内容</text>
    </view>

    <view
      wx:for="{{filteredList}}"
      wx:key="_id"
      class="baike-card"
    >
      <text class="baike-title">{{item.title}}</text>
      <text class="baike-desc">{{item.desc}}</text>
      <view class="tag-row">
        <text
          wx:for="{{item.tags}}"
          wx:key="*this"
          wx:for-item="tag"
          class="tag"
        >#{{tag}}</text>
      </view>
    </view>
  </scroll-view>
</view>
