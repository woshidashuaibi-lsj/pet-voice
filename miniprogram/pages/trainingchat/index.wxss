/* pages/trainingchat/index.wxss */

.page {
  background: #F5F7FA;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* ---- 导航栏 ---- */
.nav-clear {
  font-size: 26rpx;
  color: var(--color-gray);
  padding: 10rpx 0;
}

/* ---- 聊天列表 ---- */
.chat-list {
  flex: 1;
  padding: 24rpx 28rpx 0;
  box-sizing: border-box;
}

/* ---- 欢迎区域 ---- */
.chat-welcome {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx 20rpx;
}

.chat-welcome-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.chat-welcome-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 12rpx;
}

.chat-welcome-sub {
  font-size: 26rpx;
  color: var(--color-gray);
  text-align: center;
  line-height: 1.6;
  margin-bottom: 40rpx;
}

/* 快捷问题 */
.quick-questions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  justify-content: center;
  width: 100%;
}

.quick-btn {
  background: var(--color-white);
  border: 2rpx solid var(--color-border);
  border-radius: 32rpx;
  padding: 14rpx 28rpx;
  font-size: 24rpx;
  color: var(--color-text);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

/* ---- 消息行 ---- */
.msg-row {
  display: flex;
  align-items: flex-end;
  margin-bottom: 28rpx;
  gap: 14rpx;
}

.msg-left  { flex-direction: row; }
.msg-right { flex-direction: row-reverse; }

/* 头像 */
.msg-avatar {
  font-size: 40rpx;
  width: 64rpx;
  height: 64rpx;
  background: var(--color-white);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
}

.user-avatar {
  background: var(--color-primary-light);
}

/* 气泡 */
.msg-bubble {
  max-width: 72%;
  padding: 22rpx 28rpx;
  border-radius: 24rpx;
  line-height: 1.7;
}

.bubble-user {
  background: var(--color-primary);
  border-bottom-right-radius: 8rpx;
}

.bubble-ai {
  background: var(--color-white);
  border-bottom-left-radius: 8rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.msg-text {
  font-size: 28rpx;
  white-space: pre-wrap;
  word-break: break-all;
}

.bubble-user .msg-text { color: #fff; }
.bubble-ai  .msg-text  { color: var(--color-text); }

/* loading 气泡 */
.bubble-loading {
  min-width: 80rpx;
  min-height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-dots {
  display: flex;
  gap: 10rpx;
  align-items: center;
}

.dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: var(--color-gray);
  animation: dotBounce 1.2s infinite ease-in-out;
}

.dot2 { animation-delay: 0.2s; }
.dot3 { animation-delay: 0.4s; }

@keyframes dotBounce {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
  40%           { transform: scale(1);   opacity: 1; }
}

/* ---- 输入栏 ---- */
.input-bar {
  display: flex;
  align-items: flex-end;
  gap: 16rpx;
  padding: 20rpx 28rpx;
  background: var(--color-white);
  border-top: 1rpx solid var(--color-border);
  box-sizing: border-box;
  flex-shrink: 0;
}

.input-box {
  flex: 1;
  background: #F5F7FA;
  border-radius: 24rpx;
  padding: 18rpx 24rpx;
  font-size: 28rpx;
  color: var(--color-text);
  min-height: 72rpx;
  max-height: 200rpx;
  line-height: 1.5;
}

.input-placeholder { color: #B0B0B0; }

.send-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #D0D0D0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: background 0.15s;
}

.send-active { background: var(--color-primary); }

.send-icon {
  font-size: 36rpx;
  color: #fff;
  font-weight: 700;
  line-height: 1;
}
