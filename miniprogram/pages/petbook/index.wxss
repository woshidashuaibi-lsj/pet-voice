/* pages/petbook/index.wxss */

.page {
  background: #F2F4F7;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* ========== Header ========== */
.header-bg {
  background: linear-gradient(145deg, #FF9F43 0%, #FF6B35 100%);
  flex-shrink: 0;
}

.nav-row {
  display: flex;
  align-items: center;
  padding: 0 32rpx;
}

.nav-back {
  font-size: 56rpx;
  color: #fff;
  width: 60rpx;
  line-height: 1;
  padding-bottom: 4rpx;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
}

.nav-placeholder { width: 60rpx; }

/* 宠物英雄区 */
.pet-hero {
  display: flex;
  align-items: center;
  padding: 12rpx 40rpx 48rpx;
  gap: 28rpx;
}

.pet-hero-avatar {
  width: 110rpx;
  height: 110rpx;
  background: rgba(255,255,255,0.25);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border: 3rpx solid rgba(255,255,255,0.5);
}

.pet-hero-emoji { font-size: 60rpx; }

.pet-hero-info { flex: 1; }

.pet-hero-name {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  color: #fff;
  margin-bottom: 12rpx;
}

.pet-hero-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.hero-tag {
  background: rgba(255,255,255,0.25);
  color: #fff;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.hero-edit-btn {
  font-size: 26rpx;
  color: rgba(255,255,255,0.9);
  background: rgba(255,255,255,0.2);
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  flex-shrink: 0;
}

/* 圆弧过渡 */
.header-arc {
  height: 36rpx;
  background: #F2F4F7;
  border-radius: 36rpx 36rpx 0 0;
  margin-top: -2rpx;
}

/* ========== 内容区 ========== */
.content-wrap {
  flex: 1;
  padding: 4rpx 0 0;
}

/* ---- 空状态 ---- */
.empty-card {
  background: #fff;
  border-radius: 24rpx;
  margin: 16rpx 28rpx;
  padding: 80rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.empty-tip { font-size: 30rpx; color: #666; margin-bottom: 40rpx; }

.empty-btn {
  background: linear-gradient(135deg, #FF9F43, #FF6B35);
  color: #fff;
  border-radius: 48rpx;
  font-size: 30rpx;
  border: none;
  height: 88rpx;
  line-height: 88rpx;
  width: 280rpx;
}

/* ---- 基础数据条 ---- */
.stat-row {
  background: #fff;
  border-radius: 20rpx;
  margin: 12rpx 28rpx;
  padding: 28rpx 0;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-val {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
}

.stat-divider {
  width: 1rpx;
  height: 44rpx;
  background: #EFEFEF;
}

/* ---- 通用卡片 ---- */
.section-card {
  background: #fff;
  border-radius: 20rpx;
  margin: 12rpx 28rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.section-icon { font-size: 32rpx; }

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
}

.section-add {
  font-size: 26rpx;
  color: #FF9F43;
  font-weight: 500;
}

.section-edit {
  font-size: 26rpx;
  color: #999;
}

/* ---- 性格标签 ---- */
.trait-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.trait-tag {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: #FFF3E8;
  color: #FF7043;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.trait-del {
  font-size: 24rpx;
  color: #FF9F43;
  margin-left: 2rpx;
}

/* ---- 习性内容 ---- */
.habit-content {
  background: #F8F9FA;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
}

.habit-text {
  font-size: 28rpx;
  color: #444;
  line-height: 1.7;
}

/* ---- 空提示 ---- */
.empty-hint {
  font-size: 26rpx;
  color: #C0C0C0;
  padding: 8rpx 0;
}

/* ---- 成长备忘 ---- */
.memo-item {
  border-bottom: 1rpx solid #F0F0F0;
  padding: 16rpx 0;
}

.memo-item:last-child { border-bottom: none; }

.memo-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.memo-date { font-size: 22rpx; color: #999; }

.memo-del { font-size: 22rpx; color: #CCC; }

.memo-content {
  display: block;
  font-size: 28rpx;
  color: #444;
  line-height: 1.7;
}

/* ========== 底部弹层通用 ========== */
.mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 9998;
}

.bottom-sheet {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  z-index: 9999;
  background: #fff;
  border-radius: 40rpx 40rpx 0 0;
  padding: 12rpx 40rpx 60rpx;
  max-height: 78vh;
  overflow-y: auto;
}

.tall-sheet { max-height: 90vh; }

.sheet-handle {
  width: 80rpx;
  height: 8rpx;
  background: #E0E0E0;
  border-radius: 4rpx;
  margin: 8rpx auto 24rpx;
}

.sheet-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.sheet-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.sheet-close {
  font-size: 36rpx;
  color: #999;
  padding: 8rpx;
}

.sheet-title-center {
  display: block;
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 36rpx;
}

/* ---- 预设标签 ---- */
.preset-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.preset-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.preset-tag {
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  background: #F5F5F5;
  color: #555;
  border: 2rpx solid transparent;
}

.preset-tag.selected {
  background: #FFF3E8;
  color: #FF7043;
  border-color: #FF9F43;
}

/* ---- 自定义标签输入 ---- */
.custom-input-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 36rpx;
}

.custom-input {
  flex: 1;
  height: 80rpx;
  background: #F5F7FA;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.custom-add-btn {
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 32rpx;
  background: #FF9F43;
  color: #fff;
  border-radius: 16rpx;
  font-size: 28rpx;
}

/* ---- 习性文本域 ---- */
.habit-textarea {
  width: 100%;
  min-height: 160rpx;
  background: #F5F7FA;
  border-radius: 20rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
  line-height: 1.7;
  margin-bottom: 32rpx;
}

/* ---- 弹层确认按钮 ---- */
.sheet-confirm-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  background: linear-gradient(135deg, #FF9F43, #FF6B35);
  color: #fff;
  line-height: 96rpx;
}

/* ---- 基础编辑表单 ---- */
.form-row { margin-bottom: 28rpx; }

.form-label {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: #F5F7FA;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.type-row { display: flex; gap: 20rpx; }

.type-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: #F5F7FA;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #666;
  border: 2rpx solid transparent;
}

.type-btn.selected {
  border-color: #FF9F43;
  background: #FFF3E8;
  color: #FF7043;
  font-weight: 600;
}

.modal-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}

.modal-cancel {
  flex: 1;
  height: 88rpx;
  background: #F0F0F0;
  border-radius: 48rpx;
  font-size: 30rpx;
  color: #999;
  border: none;
  line-height: 88rpx;
  box-shadow: none;
}
.modal-cancel::after { border: none; }

.modal-save {
  flex: 2;
  height: 88rpx;
  background: linear-gradient(135deg, #FF9F43, #FF6B35);
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: white;
  border: none;
  line-height: 88rpx;
  box-shadow: 0 6rpx 20rpx rgba(255,107,53,0.35);
}
.modal-save::after { border: none; }

/* ========== Phase 4：Tab 切换栏 ========== */
.tab-bar {
  display: flex;
  margin: 0 32rpx 0;
  background: rgba(255,255,255,0.15);
  border-radius: 24rpx;
  padding: 6rpx;
  margin-bottom: 0;
}

.tab-item {
  flex: 1;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  font-size: 28rpx;
  color: rgba(255,255,255,0.7);
  gap: 8rpx;
  transition: all 0.2s;
}

.tab-item.tab-active {
  background: #fff;
  color: #FF7043;
  font-weight: 700;
}

.tab-badge {
  background: #FF4444;
  color: #fff;
  font-size: 18rpx;
  padding: 2rpx 10rpx;
  border-radius: 20rpx;
  min-width: 48rpx;
  text-align: center;
}

/* ========== 档案完整度卡片 ========== */
.completeness-card {
  background: #fff;
  border-radius: 20rpx;
  margin: 12rpx 28rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.completeness-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.completeness-title-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.completeness-icon { font-size: 32rpx; }

.completeness-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
}

.completeness-score {
  font-size: 36rpx;
  font-weight: 800;
  color: #FF7043;
}

.progress-bar-bg {
  width: 100%;
  height: 12rpx;
  background: #F0F0F0;
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.progress-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF9F43, #FF6B35);
  border-radius: 6rpx;
  transition: width 0.4s ease;
}

.completeness-tip {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 20rpx;
}

.missing-fields {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.missing-label {
  font-size: 24rpx;
  color: #999;
}

.missing-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.missing-tag {
  background: #FFF3E8;
  color: #FF7043;
  border: 1rpx dashed #FF9F43;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.memory-add-btn {
  background: linear-gradient(135deg, #FF9F43, #FF6B35);
  border-radius: 40rpx;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
}

/* ========== 记忆加载状态 ========== */
.memory-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}
.memory-loading-text { font-size: 28rpx; color: #999; }

/* ========== 无记忆空状态 ========== */
.empty-memory-card {
  background: #fff;
  border-radius: 20rpx;
  margin: 12rpx 28rpx;
  padding: 60rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.empty-sub {
  font-size: 24rpx;
  color: #C0C0C0;
  text-align: center;
  line-height: 1.6;
}

/* ========== 记忆分组卡片 ========== */
.memory-group-card {
  background: #fff;
  border-radius: 20rpx;
  margin: 12rpx 28rpx;
  padding: 24rpx 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.memory-group-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.memory-group-emoji { font-size: 30rpx; }

.memory-group-label {
  flex: 1;
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
}

.memory-group-count {
  font-size: 22rpx;
  color: #999;
  background: #F5F5F5;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}

/* ---- 记忆条目 ---- */
.memory-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F8F8F8;
}

.memory-item:last-child { border-bottom: none; }

.memory-item-main {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.memory-item-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.memory-item-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
}

/* 来源标签 */
.memory-source-tag {
  font-size: 20rpx;
  padding: 3rpx 14rpx;
  border-radius: 12rpx;
  width: fit-content;
}
.source-ai {
  background: #EFF3FF;
  color: #4A7FE5;
}
.source-stated {
  background: #E8F5E9;
  color: #4CAF50;
}
.source-correction {
  background: #FFF3E0;
  color: #FF9800;
}
.source-vet {
  background: #F3E8FF;
  color: #9C27B0;
}

.memory-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  display: block;
}

.memory-date {
  font-size: 20rpx;
  color: #BBBBBB;
}

.memory-delete-btn {
  font-size: 24rpx;
  color: #CCCCCC;
  padding: 4rpx 8rpx;
}

/* 置信度细条 */
.confidence-bar-bg {
  width: 100%;
  height: 4rpx;
  background: #F0F0F0;
  border-radius: 2rpx;
  overflow: hidden;
}
.confidence-bar-fill { height: 100%; border-radius: 2rpx; }
.conf-high { background: #4CAF50; }
.conf-mid  { background: #FF9F43; }
.conf-low  { background: #FFCDD2; }

/* ========== Picker 样式 ========== */
.picker-display {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 80rpx;
  background: #F5F7FA;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
}
.picker-arrow {
  font-size: 36rpx;
  color: #999;
}

/* ========== 手动添加记忆弹层 ========== */
.memory-add-tip {
  font-size: 24rpx;
  color: #999;
  background: #FFF8F0;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 28rpx;
  line-height: 1.6;
}

/* ========== 字段补充弹层 ========== */
.field-edit-input {
  margin-bottom: 20rpx;
}
.field-edit-tip {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 28rpx;
  line-height: 1.6;
}
