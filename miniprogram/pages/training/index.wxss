/* pages/training/index.wxss */

.page {
  background: linear-gradient(180deg, #FFF9F0 0%, #FFF5E6 100%);
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* ---- 导航栏 ---- */
.nav-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 32rpx;
  background: linear-gradient(180deg, rgba(255, 249, 240, 0.98) 0%, rgba(255, 245, 230, 0.95) 100%);
  backdrop-filter: blur(10rpx);
  border-bottom: 1rpx solid rgba(255, 159, 67, 0.1);
}

.nav-back {
  font-size: 30rpx;
  color: var(--color-primary);
  padding: 10rpx 0;
  font-weight: 500;
}

.nav-title-sm {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
}

/* ---- 训练顾问横幅 ---- */
.ask-banner {
  margin: 24rpx 32rpx 28rpx;
  background: linear-gradient(135deg, #FF9F43 0%, #FF7F30 100%);
  border-radius: 28rpx;
  padding: 36rpx 40rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 12rpx 40rpx rgba(255, 159, 67, 0.4);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  position: relative;
  overflow: hidden;
}

.ask-banner::before {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.25) 0%, transparent 60%);
  border-radius: 50%;
  z-index: -1;
}

.ask-banner-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
  position: relative;
  z-index: 1;
}

.ask-banner-icon {
  font-size: 64rpx;
  line-height: 1;
  animation: float 3s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12rpx); }
}

.ask-banner-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
  position: relative;
  z-index: 1;
}

.ask-banner-sub {
  display: block;
  font-size: 24rpx;
  color: rgba(255,255,255,0.9);
  position: relative;
  z-index: 1;
}

.ask-banner-arrow {
  font-size: 40rpx;
  color: #fff;
  font-weight: 600;
  position: relative;
  z-index: 1;
}

/* ---- 分类 Tab ---- */
.tab-row {
  display: flex;
  gap: 16rpx;
  padding: 0 32rpx 28rpx;
}

.tab-btn {
  padding: 14rpx 36rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: var(--color-gray);
  background: linear-gradient(135deg, #FFFFFF 0%, #FFF9F0 100%);
  border: 2rpx solid rgba(255, 159, 67, 0.15);
  box-shadow: 0 4rpx 12rpx rgba(255, 159, 67, 0.08);
  transition: all 0.3s ease;
}

.tab-active {
  color: #fff;
  background: linear-gradient(135deg, #FF9F43 0%, #FF7F30 100%);
  border-color: transparent;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(255, 159, 67, 0.4);
  transform: translateY(-2rpx);
}

/* ---- 课程列表 ---- */
.course-list {
  flex: 1;
  padding: 0 32rpx 40rpx;
  padding-right: 32rpx;
  height: calc(100vh - 480rpx);
  box-sizing: border-box;
}

.course-card {
  background: linear-gradient(135deg, #FFFFFF 0%, #FFF9F0 100%);
  border-radius: 28rpx;
  padding: 32rpx 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.course-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, var(--color-primary) 0%, transparent 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.course-card:active {
  transform: translateY(-4rpx);
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.1);
}

.course-card:active::before {
  opacity: 1;
}

.cc-header {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 20rpx;
  position: relative;
  z-index: 1;
}

.cc-tag {
  font-size: 22rpx;
  font-weight: 600;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
}

.cc-level {
  font-size: 22rpx;
  font-weight: 600;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
}

.cc-pet {
  font-size: 24rpx;
  color: var(--color-gray);
  margin-left: auto;
}

.cc-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 14rpx;
  line-height: 1.4;
  position: relative;
  z-index: 1;
}

.cc-summary {
  display: block;
  font-size: 26rpx;
  color: var(--color-gray);
  line-height: 1.7;
  margin-bottom: 20rpx;
  position: relative;
  z-index: 1;
}

.cc-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
  z-index: 1;
}

.cc-duration {
  font-size: 24rpx;
  color: var(--color-gray);
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.cc-stars {
  display: flex;
  gap: 6rpx;
}

.cc-star {
  font-size: 26rpx;
}

.star-on {
  color: #FF9F43;
  filter: drop-shadow(0 2rpx 4rpx rgba(255, 159, 67, 0.3));
}

.star-off {
  color: #E8E8E8;
}

/* ---- 空状态 ---- */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
  animation: float 3s ease-in-out infinite;
}

.empty-text {
  font-size: 28rpx;
  color: var(--color-gray);
}

/* ========== 详情弹层 ========== */
.detail-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.6);
  z-index: 100;
  display: flex;
  align-items: flex-end;
  backdrop-filter: blur(8rpx);
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.detail-sheet {
  background: linear-gradient(180deg, #FFFFFF 0%, #FFF9F0 100%);
  border-radius: 40rpx 40rpx 0 0;
  width: 100%;
  max-height: 85vh;
  height: 85vh;
  display: flex;
  flex-direction: column;
  box-shadow: 0 -8rpx 40rpx rgba(0, 0, 0, 0.15);
  animation: slideUp 0.3s ease;
  position: relative;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.detail-sheet::before {
  content: '';
  position: absolute;
  top: 12rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 80rpx;
  height: 6rpx;
  background: rgba(255, 159, 67, 0.3);
  border-radius: 6rpx;
}

.detail-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 48rpx 40rpx 28rpx;
  border-bottom: 1rpx solid rgba(255, 159, 67, 0.1);
  flex-shrink: 0;
  position: relative;
}

.detail-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text);
  flex: 1;
  line-height: 1.4;
  padding-right: 24rpx;
}

.detail-close {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 159, 67, 0.1);
  color: var(--color-primary);
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.3s ease;
}

.detail-close:active {
  background: rgba(255, 159, 67, 0.2);
  transform: scale(0.9);
}

.detail-body {
  flex: 1;
  padding: 32rpx 40rpx 48rpx;
  padding-right: 40rpx;
  overflow-y: auto;
  overflow-x: hidden;
  box-sizing: border-box;
  -webkit-overflow-scrolling: touch;
  width: 100%;
}

.detail-meta-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 28rpx;
}

.detail-pet {
  font-size: 24rpx;
  color: var(--color-gray);
  margin-left: auto;
}

/* 基本信息条 */
.detail-info-bar {
  background: linear-gradient(135deg, #FFF9F0 0%, #FFF5E6 100%);
  border-radius: 20rpx;
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-around;
  margin-bottom: 36rpx;
  border: 2rpx solid rgba(255, 159, 67, 0.15);
}

.detail-info-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.dii-label {
  font-size: 22rpx;
  color: var(--color-gray);
}

.dii-val {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
}

.detail-info-divider {
  width: 2rpx;
  height: 64rpx;
  background: rgba(255, 159, 67, 0.2);
}

/* 详情区块 */
.detail-section {
  margin-bottom: 36rpx;
}

.detail-section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 24rpx;
}

/* 训练步骤 */
.step-item {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  margin-bottom: 28rpx;
  padding: 28rpx;
  background: linear-gradient(135deg, #FFFFFF 0%, #FFF9F0 100%);
  border-radius: 24rpx;
  border: 2rpx solid rgba(255, 159, 67, 0.1);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
}

.step-item:active {
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.08);
}

.step-num {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF9F43 0%, #FF7F30 100%);
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(255, 159, 67, 0.3);
}

.step-text {
  flex: 1;
  font-size: 26rpx;
  line-height: 1.8;
  color: var(--color-text);
}

/* 训练贴士 */
.tip-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #FFF9F0 0%, #FFF5E6 100%);
  border-radius: 20rpx;
  border-left: 4rpx solid var(--color-primary);
}

.tip-dot {
  color: var(--color-primary);
  margin-right: 16rpx;
  font-size: 24rpx;
  font-weight: 600;
  margin-top: 4rpx;
}

.tip-text {
  flex: 1;
  font-size: 26rpx;
  line-height: 1.7;
  color: var(--color-text);
}

/* 底部顾问入口按钮 */
.detail-ask-btn {
  background: linear-gradient(135deg, #FF9F43 0%, #FF7F30 100%);
  border-radius: 48rpx;
  padding: 32rpx;
  text-align: center;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 159, 67, 0.4);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  transition: all 0.3s ease;
}

.detail-ask-btn:active {
  transform: translateY(-2rpx);
  box-shadow: 0 12rpx 32rpx rgba(255, 159, 67, 0.5);
}
