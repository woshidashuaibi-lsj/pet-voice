/* pages/index/index.wxss */

.page {
  background: var(--color-bg);
  min-height: 100vh;
  position: relative;
}

/* ---- 导航栏 ---- */
.nav-bar {
  display: flex;
  align-items: center;
  padding: 0 32rpx;
  background: var(--color-bg);
}

.nav-logo {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.nav-logo-icon {
  font-size: 40rpx;
  line-height: 1;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-primary);
  letter-spacing: 1rpx;
}

/* ---- 宠物欢迎行 ---- */
.welcome-row {
  display: flex;
  align-items: center;
  margin: 12rpx 32rpx 0;
  background: var(--color-white);
  border-radius: 24rpx;
  padding: 20rpx 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
}

.welcome-avatar-wrap {
  width: 72rpx;
  height: 72rpx;
  background: var(--color-primary-light);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.welcome-avatar {
  font-size: 44rpx;
  line-height: 1;
}

.welcome-name {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text);
}

.welcome-sub {
  display: block;
  font-size: 22rpx;
  color: var(--color-gray);
  margin-top: 6rpx;
}

/* ---- 录音区域 ---- */
.record-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0 36rpx;
  position: relative;
}

.record-btn {
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #FFAF53, #FF7F30);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 56rpx rgba(255, 159, 67, 0.50);
  transition: transform 0.12s ease, box-shadow 0.12s ease;
  position: relative;
  z-index: 2;
}

.record-btn.recording {
  transform: scale(1.07);
  box-shadow: 0 24rpx 80rpx rgba(255, 159, 67, 0.70);
}

.record-icon {
  font-size: 88rpx;
  margin-bottom: 10rpx;
  line-height: 1;
}

.record-text {
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
}

/* 录音中波纹 */
.ripple-wrap {
  position: absolute;
  top: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 300rpx;
  height: 300rpx;
  z-index: 1;
}

.ripple {
  position: absolute;
  border-radius: 50%;
  border: 3rpx solid rgba(255, 159, 67, 0.4);
  animation: ripple-anim 1.5s ease-out infinite;
}

.ripple-1 {
  width: 360rpx;
  height: 360rpx;
  animation-delay: 0s;
}

.ripple-2 {
  width: 430rpx;
  height: 430rpx;
  animation-delay: 0.5s;
}

@keyframes ripple-anim {
  0%   { opacity: 1; transform: scale(0.9); }
  100% { opacity: 0; transform: scale(1.1); }
}

.record-hint {
  margin-top: 28rpx;
  color: var(--color-gray);
  font-size: 26rpx;
}

/* ---- 5宫格功能入口 ---- */
.func-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 16rpx;
  padding: 0 28rpx 32rpx;
}

.func-item {
  background: var(--color-white);
  border-radius: 20rpx;
  padding: 24rpx 8rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  position: relative;
}

.func-hover {
  opacity: 0.85;
}

/* 图标背景圆 */
.func-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.func-icon-blue   { background: #EBF5FB; }
.func-icon-green  { background: #EAFAF1; }
.func-icon-orange { background: #FEF9E7; }
.func-icon-purple { background: #F5EEF8; }
.func-icon-gray   { background: #F2F3F4; }

.func-icon {
  font-size: 40rpx;
  line-height: 1;
}

.func-text {
  font-size: 22rpx;
  color: var(--color-text);
  font-weight: 500;
  text-align: center;
}

/* ---- 未填档案提示 ---- */
.tip-card {
  margin: 12rpx 32rpx 0;
  background: var(--color-primary-light);
  border-radius: 20rpx;
  padding: 22rpx 28rpx;
  display: flex;
  align-items: center;
  border: 2rpx solid rgba(255, 159, 67, 0.2);
}

.tip-icon {
  font-size: 32rpx;
  margin-right: 14rpx;
}

.tip-text {
  flex: 1;
  font-size: 26rpx;
  color: var(--color-primary);
}

.tip-arrow {
  font-size: 28rpx;
  color: var(--color-primary);
}

/* ---- 右下角悬浮打卡按钮 ---- */
.fab-checkin {
  position: fixed;
  right: 36rpx;
  bottom: calc(120rpx + env(safe-area-inset-bottom));
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: var(--color-white);
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.12);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  z-index: 50;
}

.fab-icon {
  font-size: 40rpx;
  line-height: 1;
}

.fab-label {
  font-size: 20rpx;
  color: var(--color-gray);
  font-weight: 500;
}

.fab-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  background: #E0E0E0;
  color: #999;
  font-size: 16rpx;
  padding: 4rpx 10rpx;
  border-radius: 16rpx;
  white-space: nowrap;
}

/* func-locked: 置灰不可交互 */
.func-locked {
  opacity: 0.5;
}
