/* pages/index/index.wxss */

.page {
  background: linear-gradient(180deg, #FFF9F0 0%, #FFE8CC 100%);
  min-height: 100vh;
  position: relative;
  overflow: hidden;
}

/* 可爱装饰元素 - 星星 */
.page::before {
  content: '';
  position: absolute;
  top: 120rpx;
  right: 60rpx;
  width: 32rpx;
  height: 32rpx;
  background: radial-gradient(circle, rgba(255, 215, 0, 0.4) 0%, transparent 70%);
  border-radius: 50%;
  animation: twinkle 2s ease-in-out infinite;
}

.page::after {
  content: '';
  position: absolute;
  top: 280rpx;
  left: 80rpx;
  width: 24rpx;
  height: 24rpx;
  background: radial-gradient(circle, rgba(255, 159, 67, 0.3) 0%, transparent 70%);
  border-radius: 50%;
  animation: twinkle 2.5s ease-in-out infinite 0.5s;
}

/* 云朵装饰 */
.cloud-decoration {
  position: absolute;
  font-size: 80rpx;
  opacity: 0.15;
  animation: float-cloud 6s ease-in-out infinite;
  z-index: 0;
}

.cloud-1 {
  top: 180rpx;
  left: 40rpx;
}

.cloud-2 {
  top: 320rpx;
  right: 50rpx;
  animation-delay: 2s;
}

.cloud-3 {
  top: 700rpx;
  left: 80rpx;
  animation-delay: 4s;
}

@keyframes twinkle {
  0%, 100% { opacity: 0.3; transform: scale(1); }
  50% { opacity: 0.6; transform: scale(1.2); }
}

@keyframes float-cloud {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-16rpx); }
}

/* ---- 导航栏 ---- */
.nav-bar {
  display: flex;
  align-items: center;
  padding: 0 32rpx;
  background: linear-gradient(180deg, rgba(255, 249, 240, 0.95) 0%, rgba(255, 232, 204, 0.9) 100%);
  backdrop-filter: blur(10rpx);
  position: relative;
  z-index: 10;
}

.nav-logo {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.nav-logo-icon {
  font-size: 44rpx;
  line-height: 1;
  animation: bounce-gentle 2s ease-in-out infinite;
}

@keyframes bounce-gentle {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  25% { transform: translateY(-6rpx) rotate(-5deg); }
  75% { transform: translateY(-6rpx) rotate(5deg); }
}

.nav-title {
  font-size: 38rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #FF9F43 0%, #FF7F30 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: 2rpx;
}

/* ---- 主滚动区 ---- */
.main-scroll {
  height: 100vh;
}

/* ---- 宠物欢迎卡片 ---- */
.welcome-card {
  margin: 24rpx 32rpx 0;
  background: linear-gradient(135deg, #FFFFFF 0%, #FFF9F0 100%);
  border-radius: 32rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 159, 67, 0.12);
  border: 2rpx solid rgba(255, 159, 67, 0.15);
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  transition: all 0.3s ease;
}

.welcome-card:active {
  transform: translateY(-4rpx);
  box-shadow: 0 12rpx 32rpx rgba(255, 159, 67, 0.18);
}

.welcome-avatar-wrap {
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #FFECD6 0%, #FFD8A8 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 28rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(255, 159, 67, 0.2);
  border: 3rpx solid #fff;
  animation: pulse-avatar 2s ease-in-out infinite;
}

@keyframes pulse-avatar {
  0%, 100% { box-shadow: 0 4rpx 12rpx rgba(255, 159, 67, 0.2); }
  50% { box-shadow: 0 8rpx 20rpx rgba(255, 159, 67, 0.35); }
}

.welcome-avatar {
  font-size: 56rpx;
  line-height: 1;
  animation: wiggle 3s ease-in-out infinite;
}

@keyframes wiggle {
  0%, 100% { transform: rotate(0deg); }
  25% { transform: rotate(-8deg); }
  75% { transform: rotate(8deg); }
}

.welcome-info {
  flex: 1;
}

.welcome-name {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 8rpx;
}

.welcome-sub {
  display: block;
  font-size: 26rpx;
  color: var(--color-primary);
  font-weight: 500;
}

.welcome-card-hover {
  opacity: 0.88;
  transform: translateY(-2rpx);
}

/* 分身入口徽章 */
.avatar-entry-badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  background: linear-gradient(135deg, #FF9F43 0%, #FF7F30 100%);
  border-radius: 20rpx;
  padding: 12rpx 18rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(255, 159, 67, 0.35);
}

.avatar-entry-icon {
  font-size: 28rpx;
  line-height: 1;
}

.avatar-entry-text {
  font-size: 20rpx;
  color: #fff;
  font-weight: 700;
}

@keyframes float-heart {
  0%, 100% { transform: translateY(0) scale(1); }
  50% { transform: translateY(-8rpx) scale(1.1); }
}

/* ---- 功能入口区域 ---- */
.func-section {
  padding: 0 32rpx;
  position: relative;
  z-index: 1;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 24rpx;
  text-align: center;
}

.func-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding-bottom: 140rpx;
}

.func-row {
  display: flex;
  gap: 20rpx;
}

.func-row:only-child {
  justify-content: center;
}

/* 功能卡片 */
.func-card {
  flex: 1;
  background: linear-gradient(135deg, #FFFFFF 0%, #FFF9F0 100%);
  border-radius: 28rpx;
  padding: 28rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  border: 2rpx solid rgba(255, 159, 67, 0.1);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.func-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, var(--color-primary) 0%, transparent 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.func-card:active {
  transform: translateY(-6rpx);
  box-shadow: 0 12rpx 32rpx rgba(255, 159, 67, 0.18);
}

.func-card:active::before {
  opacity: 1;
}

.func-card-hover {
  opacity: 0.9;
}

/* 卡片颜色变体 */
.func-card-blue {
  border-color: rgba(52, 152, 219, 0.15);
}

.func-card-blue .func-card-icon {
  background: linear-gradient(135deg, #EBF5FB 0%, #D6EAF8 100%);
  border-color: #AED6F1;
}

.func-card-green {
  border-color: rgba(46, 204, 113, 0.15);
}

.func-card-green .func-card-icon {
  background: linear-gradient(135deg, #EAFAF1 0%, #D5F5E3 100%);
  border-color: #A9DFBF;
}

.func-card-orange {
  border-color: rgba(255, 159, 67, 0.15);
}

.func-card-orange .func-card-icon {
  background: linear-gradient(135deg, #FEF9E7 0%, #FCF3CF 100%);
  border-color: #F9E79F;
}

.func-card-purple {
  border-color: rgba(155, 89, 182, 0.15);
}

.func-card-purple .func-card-icon {
  background: linear-gradient(135deg, #F5EEF8 0%, #EBDEF0 100%);
  border-color: #D7BDE2;
}

.func-card-gray {
  border-color: rgba(189, 195, 199, 0.15);
}

.func-card-gray .func-card-icon {
  background: linear-gradient(135deg, #F8F9F9 0%, #E8E8E8 100%);
  border-color: #BDC3C7;
}

.func-card-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  border: 2rpx solid;
  position: relative;
  z-index: 1;
}

.func-card-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  position: relative;
  z-index: 1;
}

.func-card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
}

.func-card-desc {
  font-size: 22rpx;
  color: var(--color-gray);
}

/* ---- 未填档案提示 ---- */
.tip-card {
  margin: 20rpx 32rpx 0;
  background: linear-gradient(135deg, #FFF5E6 0%, #FFECD6 100%);
  border-radius: 28rpx;
  padding: 28rpx 32rpx;
  display: flex;
  align-items: center;
  border: 2rpx solid rgba(255, 159, 67, 0.25);
  box-shadow: 0 6rpx 20rpx rgba(255, 159, 67, 0.15);
  position: relative;
  z-index: 1;
  transition: all 0.3s ease;
}

.tip-card:active {
  transform: translateY(-4rpx);
  box-shadow: 0 10rpx 28rpx rgba(255, 159, 67, 0.2);
}

.tip-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
  animation: bounce-gentle 2s ease-in-out infinite 0.3s;
}

.tip-text {
  flex: 1;
  font-size: 28rpx;
  color: #E67E22;
  font-weight: 600;
}

.tip-arrow {
  font-size: 32rpx;
  color: #E67E22;
  font-weight: 700;
}

/* ---- 右下角悬浮打卡按钮 ---- */
.fab-checkin {
  position: fixed;
  right: 40rpx;
  bottom: calc(140rpx + env(safe-area-inset-bottom));
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFFFFF 0%, #FFF9F0 100%);
  box-shadow: 0 10rpx 40rpx rgba(0,0,0,0.15);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  z-index: 50;
  border: 3rpx solid rgba(255, 159, 67, 0.2);
}

.fab-icon {
  font-size: 44rpx;
  line-height: 1;
}

.fab-label {
  font-size: 22rpx;
  color: var(--color-primary);
  font-weight: 600;
}

.fab-badge {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  background: linear-gradient(135deg, #FF9F43 0%, #FF7F30 100%);
  color: #fff;
  font-size: 18rpx;
  padding: 6rpx 14rpx;
  border-radius: 20rpx;
  white-space: nowrap;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(255, 159, 67, 0.3);
}

/* func-locked: 置灰不可交互 */
.func-locked {
  opacity: 0.4;
}

/* ---- 宠物装饰元素 ---- */
.pet-decoration {
  position: absolute;
  font-size: 60rpx;
  opacity: 0.2;
  z-index: 0;
  animation: float-pet 4s ease-in-out infinite;
}

.pet-cat-1 {
  top: 480rpx;
  left: 30rpx;
  animation-delay: 0s;
}

.pet-dog-1 {
  top: 520rpx;
  right: 40rpx;
  animation-delay: 1s;
}

.pet-cat-2 {
  top: 900rpx;
  left: 50rpx;
  animation-delay: 2s;
}

.pet-dog-2 {
  top: 940rpx;
  right: 60rpx;
  animation-delay: 1.5s;
}

@keyframes float-pet {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  25% { transform: translateY(-12rpx) rotate(3deg); }
  75% { transform: translateY(-8rpx) rotate(-3deg); }
}

/* ---- 底部装饰 ---- */
.bottom-decoration {
  position: absolute;
  bottom: 160rpx;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 40rpx;
  z-index: 0;
  opacity: 0.15;
}

.bottom-paw {
  font-size: 80rpx;
  animation: bounce-paw 2s ease-in-out infinite;
}

.bottom-heart {
  font-size: 60rpx;
  animation: float-heart 2s ease-in-out infinite 0.5s;
}

@keyframes bounce-paw {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}
