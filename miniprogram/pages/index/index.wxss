/* pages/index/index.wxss */

.page {
  background: var(--color-bg);
  min-height: 100vh;
}

/* ---- 导航栏 ---- */
.nav-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 32rpx;
  background: var(--color-bg);
}

.nav-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-primary);
  letter-spacing: 1rpx;
}

.nav-setting {
  font-size: 44rpx;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ---- 宠物欢迎行 ---- */
.welcome-row {
  display: flex;
  align-items: center;
  padding: 16rpx 32rpx 0;
}

.welcome-avatar {
  font-size: 56rpx;
  margin-right: 16rpx;
}

.welcome-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
}

.welcome-sub {
  display: block;
  font-size: 22rpx;
  color: var(--color-gray);
  margin-top: 4rpx;
}

/* ---- 录音区域 ---- */
.record-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 48rpx;
  position: relative;
}

.record-btn {
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #FFAF53, #FF7F30);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 60rpx rgba(255, 159, 67, 0.50);
  transition: transform 0.12s ease, box-shadow 0.12s ease;
  position: relative;
  z-index: 2;
}

.record-btn.recording {
  transform: scale(1.07);
  box-shadow: 0 24rpx 80rpx rgba(255, 159, 67, 0.70);
}

.record-icon {
  font-size: 96rpx;
  margin-bottom: 12rpx;
  line-height: 1;
}

.record-text {
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
}

/* 录音中波纹 */
.ripple-wrap {
  position: absolute;
  top: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 320rpx;
  height: 320rpx;
  z-index: 1;
}

.ripple {
  position: absolute;
  border-radius: 50%;
  border: 3rpx solid rgba(255, 159, 67, 0.4);
  animation: ripple-anim 1.5s ease-out infinite;
}

.ripple-1 {
  width: 380rpx;
  height: 380rpx;
  animation-delay: 0s;
}

.ripple-2 {
  width: 450rpx;
  height: 450rpx;
  animation-delay: 0.5s;
}

@keyframes ripple-anim {
  0%   { opacity: 1; transform: scale(0.9); }
  100% { opacity: 0; transform: scale(1.1); }
}

.record-hint {
  margin-top: 32rpx;
  color: var(--color-gray);
  font-size: 26rpx;
}

/* ---- 6宫格 ---- */
.func-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  padding: 0 32rpx 28rpx;
}

.func-item {
  background: var(--color-white);
  border-radius: 24rpx;
  padding: 32rpx 12rpx 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  position: relative;
}

.func-hover {
  background: #f5f5f5;
}

.func-icon {
  font-size: 52rpx;
  margin-bottom: 10rpx;
  line-height: 1;
}

.func-text {
  font-size: 26rpx;
  color: var(--color-text);
  font-weight: 500;
}

.func-locked {
  opacity: 0.4;
}

.func-soon {
  font-size: 18rpx;
  color: var(--color-gray);
  margin-top: 6rpx;
}

/* ---- 今日心情卡 ---- */
.mood-card {
  margin: 0 32rpx 20rpx;
  background: var(--color-white);
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.mood-icon-sm {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.mood-text-sm {
  flex: 1;
  color: var(--color-green);
  font-size: 28rpx;
  font-weight: 500;
}

.mood-arrow {
  font-size: 28rpx;
  color: var(--color-gray);
}

/* ---- 未填档案提示 ---- */
.tip-card {
  margin: 0 32rpx;
  background: var(--color-primary-light);
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  display: flex;
  align-items: center;
  border: 2rpx solid rgba(255, 159, 67, 0.2);
}

.tip-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.tip-text {
  flex: 1;
  font-size: 26rpx;
  color: var(--color-primary);
}

.tip-arrow {
  font-size: 28rpx;
  color: var(--color-primary);
}


