<!-- pages/index/index.wxml -->
<view class="page">
  <!-- 可爱装饰：云朵 -->
  <text class="cloud-decoration cloud-1">☁️</text>
  <text class="cloud-decoration cloud-2">☁️</text>
  <text class="cloud-decoration cloud-3">☁️</text>

  <!-- 可爱装饰：小动物 -->
  <text class="pet-decoration pet-cat-1">🐱</text>
  <text class="pet-decoration pet-dog-1">🐕</text>
  <text class="pet-decoration pet-cat-2">🐱</text>
  <text class="pet-decoration pet-dog-2">🐕</text>

  <!-- 状态栏占位 -->
  <view style="height: {{statusBarHeight}}px;"></view>

  <!-- 顶部导航栏 -->
  <view class="nav-bar" style="height: {{navBarHeight}}px;">
    <view class="nav-logo">
      <text class="nav-logo-icon">🐾</text>
      <text class="nav-title">毛孩子翻译官</text>
    </view>
  </view>

  <!-- 主内容区 -->
  <scroll-view scroll-y class="main-scroll">
    <!-- 宠物欢迎语（点击跳转分身页） -->
    <navigator url="/pages/avatar/index" class="welcome-card" wx:if="{{petName}}" hover-class="welcome-card-hover">
      <view class="welcome-avatar-wrap">
        <text class="welcome-avatar">{{petType === 'cat' ? '🐱' : '🐕'}}</text>
      </view>
      <view class="welcome-info">
        <text class="welcome-name">{{petName}}</text>
        <text class="welcome-sub">点我看看分身吧 ✨</text>
      </view>
      <view class="avatar-entry-badge">
        <text class="avatar-entry-icon">✨</text>
        <text class="avatar-entry-text">分身</text>
      </view>
    </navigator>

    <!-- 无宠物时的引导提示 -->
    <view class="tip-card" wx:if="{{!petName}}" bindtap="goProfile">
      <text class="tip-icon">🐾</text>
      <text class="tip-text">先填写宠物档案，翻译更准确</text>
      <text class="tip-arrow">→</text>
    </view>

    <!-- 功能入口卡片 -->
    <view class="func-section">
      <text class="section-title">✨ 探索更多</text>

      <view class="func-grid">
        <!-- 第一行：百科 + 指南 -->
        <view class="func-row">
          <navigator url="/pages/baike/index" class="func-card func-card-blue" hover-class="func-card-hover">
            <view class="func-card-icon">📖</view>
            <view class="func-card-info">
              <text class="func-card-title">百科</text>
              <text class="func-card-desc">宠物知识库</text>
            </view>
          </navigator>

          <navigator url="/pages/guide/index" class="func-card func-card-green" hover-class="func-card-hover">
            <view class="func-card-icon">📋</view>
            <view class="func-card-info">
              <text class="func-card-title">指南</text>
              <text class="func-card-desc">养护小贴士</text>
            </view>
          </navigator>
        </view>

        <!-- 第二行：健康 + 训练 -->
        <view class="func-row">
          <navigator url="/pages/health/index" class="func-card func-card-orange" hover-class="func-card-hover">
            <view class="func-card-icon">💊</view>
            <view class="func-card-info">
              <text class="func-card-title">健康</text>
              <text class="func-card-desc">健康咨询</text>
            </view>
          </navigator>

          <navigator url="/pages/training/index" class="func-card func-card-purple" hover-class="func-card-hover">
            <view class="func-card-icon">🎓</view>
            <view class="func-card-info">
              <text class="func-card-title">训练</text>
              <text class="func-card-desc">行为矫正</text>
            </view>
          </navigator>
        </view>

        <!-- 第三行：档案 -->
        <view class="func-row">
          <navigator url="/pages/petbook/index" class="func-card func-card-gray" hover-class="func-card-hover">
            <view class="func-card-icon">📓</view>
            <view class="func-card-info">
              <text class="func-card-title">档案</text>
              <text class="func-card-desc">宠物信息</text>
            </view>
          </navigator>
        </view>
      </view>
    </view>

    <!-- 底部装饰 -->
    <view class="bottom-decoration">
      <text class="bottom-paw">🐾</text>
      <text class="bottom-heart">💕</text>
    </view>

    <view style="height: 140rpx;"></view>
  </scroll-view>
</view>
